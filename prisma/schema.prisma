generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String
  price       Float
  currency    String   @default("EUR")
  category    String
  brand       String
  images      String   @default("[]")
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String   @default("")
  author      String   @default("Marios Komninakis")
  publishedAt DateTime @default(now())
  tags        String   @default("[]")
  mediumUrl   String   @default("")
}

model User {
  id                     Int            @id @default(autoincrement())
  email                  String         @unique
  passwordHash           String
  name                   String         @default("")
  phone                  String         @default("")
  addressStreet          String         @default("")
  addressCity            String         @default("")
  addressPostalCode      String         @default("")
  addressCountry         String         @default("")
  stripeCustomerId       String         @default("")
  isAdmin                Boolean        @default(false)
  membershipStatus       String         @default("none")
  membershipExpiresAt    DateTime?
  stripeSubscriptionId   String         @default("")
  createdAt              DateTime       @default(now())
  orders                 Order[]
  forumPosts             ForumPost[]
  forumComments          ForumComment[]
  chatMessages           ChatMessage[]
}

model Order {
  id                     Int      @id @default(autoincrement())
  userId                 Int?
  user                   User?    @relation(fields: [userId], references: [id])
  stripeSessionId        String   @unique
  stripePaymentIntentId  String   @default("")
  status                 String   @default("paid")
  items                  String   @default("[]")
  subtotal               Float    @default(0)
  shippingCost           Float    @default(0)
  total                  Float    @default(0)
  customerEmail          String   @default("")
  shippingName           String   @default("")
  shippingPhone          String   @default("")
  shippingStreet         String   @default("")
  shippingCity           String   @default("")
  shippingPostalCode     String   @default("")
  shippingCountry        String   @default("")
  createdAt              DateTime @default(now())
}

model ForumPost {
  id           Int            @id @default(autoincrement())
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  categorySlug String
  title        String
  content      String
  videoUrl     String         @default("")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  comments     ForumComment[]

  @@index([categorySlug])
  @@index([userId])
}

model ForumComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      ForumPost @relation(fields: [postId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model DiscoveryBooking {
  id        Int      @id @default(autoincrement())
  name      String   @default("")
  email     String   @default("")
  date      String
  time      String
  locale    String   @default("en")
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([date, time])
}
